APP_NAME=InfoMatt360 Core API
APP_VERSION=0.1.0
ENVIRONMENT=production
DEBUG=false
AUTO_CREATE_TABLES=false

# Usar PostgreSQL en produccion.
DATABASE_URL=postgresql+psycopg2://infomatt360:CHANGE_ME@db.example.com:5432/infomatt360
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800

# Generar con: .\scripts\generate-secret.cmd
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_COOKIE_NAME=infomatt360_refresh
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAMESITE=strict
JWT_ALGORITHM=HS256

UPLOAD_DIRECTORY=/var/lib/infomatt360/uploads
DEFAULT_MAX_FILE_SIZE_MB=25
FRONTEND_URL=https://app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com

# SMTP real requerido para recuperacion de contrasena.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=notifications@example.com
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
SMTP_FROM_EMAIL=notifications@example.com
SMTP_USE_TLS=true

# Proteccion global contra abuso de API.
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS=120
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_API_KEY_REQUESTS=10000
API_RATE_LIMIT_HIGH_VOLUME_REQUESTS=1000000
API_RATE_LIMIT_TRUSTED_PROXY_IPS=10.0.0.10
REDIS_URL=redis://redis.example.com:6379/0
API_RATE_LIMIT_BACKEND=redis
API_RATE_LIMIT_REDIS_PREFIX=infomatt360:rate-limit
AUTH_THROTTLE_BACKEND=redis
AUTH_THROTTLE_REDIS_PREFIX=infomatt360:auth-throttle
API_KEY_PROFILE_CACHE_TTL_SECONDS=30
REQUEST_LOGGING_ENABLED=true
REQUEST_ID_HEADER=X-Request-ID
METRICS_ENABLED=true
BULK_WORKER_RETRY_BACKOFF_SECONDS=60
BULK_WORKER_RETRY_MAX_BACKOFF_SECONDS=3600
BULK_WORKER_STALE_AFTER_SECONDS=1800
BULK_WORKER_HEARTBEAT_EVERY_RECORDS=100
SECURITY_HEADERS_ENABLED=true
CONTENT_SECURITY_POLICY=default-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'
REFERRER_POLICY=no-referrer
PERMISSIONS_POLICY=geolocation=(), microphone=(), camera=()
X_FRAME_OPTIONS=DENY
